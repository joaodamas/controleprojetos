# ═══════════════════════════════════════════════════════
# AXON Projects - Variáveis de Ambiente
# ═══════════════════════════════════════════════════════

# ─── Obrigatórios (backend Python / FastAPI) ───
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RESEND_API_KEY=re_...

# ─── Firebase Admin SDK ───
# Caminho para o arquivo de service account JSON (ou use Application Default Credentials)
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json
FIREBASE_DATABASE_URL=https://controle-projetos-a55d5-default-rtdb.firebaseio.com

# ─── Ambiente ───
# "production" desabilita /docs do FastAPI
ENVIRONMENT=development

# ─── URLs de redirecionamento Stripe ───
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/pricing
DASHBOARD_URL=http://localhost:3000/dashboard

# ─── CORS (separar origens por vírgula) ───
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ─── Produção (descomentar e ajustar) ───
# ENVIRONMENT=production
# CORS_ORIGINS=https://controle-projetos-a55d5.web.app,https://seu-dominio.com
# STRIPE_SUCCESS_URL=https://seu-dominio.com/dashboard?session_id={CHECKOUT_SESSION_ID}
# STRIPE_CANCEL_URL=https://seu-dominio.com/pricing
# DASHBOARD_URL=https://seu-dominio.com/dashboard
