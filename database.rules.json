{
  "rules": {
    "workspaces": {
      "$workspaceId": {
        ".read": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
        ".write": "auth != null && (newData.child('ownerId').val() === auth.uid || root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
        "clients": {
          ".read": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
          ".write": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
          "$clientId": {
            ".read": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
            ".write": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())"
          }
        },
        "groups": {
          ".read": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
          ".write": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
          "$groupId": {
            ".read": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())",
            ".write": "auth != null && (root.child('workspaces/' + $workspaceId + '/ownerId').val() === auth.uid || root.child('users/' + auth.uid + '/workspaces/' + $workspaceId).exists())"
          }
        }
      }
    },

    "clients": {
      ".read": "auth != null && root.child('users/' + auth.uid + '/isAdmin').val() === true",
      ".write": "auth != null && root.child('users/' + auth.uid + '/isAdmin').val() === true",
      "$clientId": {
        ".read": "auth != null && root.child('users/' + auth.uid + '/isAdmin').val() === true",
        ".write": "auth != null && root.child('users/' + auth.uid + '/isAdmin').val() === true"
      }
    },

    "groups": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('users/' + auth.uid + '/isAdmin').val() === true"
    },

    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users/' + auth.uid + '/isAdmin').val() === true)",
        ".write": "auth != null && (auth.uid === $uid || root.child('users/' + auth.uid + '/isAdmin').val() === true)"
      }
    },

    "tenants": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        "$child": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },

    "audit_logs": {
      "$tenantId": {
        ".read": "auth != null && (auth.uid === $tenantId || root.child('users/' + auth.uid + '/isAdmin').val() === true)",
        ".write": "auth != null && auth.uid === $tenantId",
        "$logId": {
          ".validate": "newData.hasChildren(['action', 'timestamp', 'userId'])"
        }
      }
    },

    ".read": false,
    ".write": false
  }
}
